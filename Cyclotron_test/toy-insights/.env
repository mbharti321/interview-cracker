# Environment variables for Toy Insights

# Database
DATABASE_URL=sqlite:///./toy_insights.db
# For PostgreSQL: postgresql://user:password@localhost:5432/toy_insights_db

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# RAG Configuration
CHUNK_SIZE=300
CHUNK_OVERLAP=50
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_INDEX_DIR=data/vectors

# Azure (optional)
# AZURE_KEY_VAULT_URL=https://<vault-name>.vault.azure.net/
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
